#!/usr/bin/env bash
# --- $NULL SOVEREIGN SDK CLI WRAPPER ---
# Policy: Data Sovereignty / Path C (Public Recovery)
set -euo pipefail

IMAGE="nullaai/liquefy-decoder-public@sha256:b7a0499f38d192e7333c760fcf8e429abcff83e58610259841f2ffb525c02935"

usage() {
  cat <<EOF
Usage:
  ./liquefy version
  ./liquefy verify <archive>
  ./liquefy decompress <archive> <output>
  ./liquefy benchmark [--lines N]
  ./liquefy benchmark-suite [--lines N] [--dataset NAME] [--no-search]

Notes:
  - verify/decompress use the pinned Docker decoder (offline, --network=none).
  - benchmark/benchmark-suite use the Python engines directly (no Docker needed).
EOF
}

cmd="${1:-}"
if [[ -z "$cmd" ]]; then usage; exit 2; fi

# Python-only commands — no Docker required
case "$cmd" in
  benchmark)
    shift
    exec python3 "$(dirname "$0")/tools/benchmark.py" "$@"
    ;;
  benchmark-suite)
    shift
    exec python3 "$(dirname "$0")/tools/benchmark_suite.py" "$@"
    ;;
esac

if ! command -v docker >/dev/null 2>&1; then
  echo "ERROR: Docker is required for verify/decompress. Install Docker or use the Python engines directly." >&2
  exit 2
fi

case "$cmd" in
  version)
    echo "[+] Ensuring latest hardened machine is available..."
    docker pull "$IMAGE" >/dev/null
    docker run --rm --network=none --read-only --cap-drop=ALL "$IMAGE" version
    ;;
  verify)
    archive="${2:-}"
    [[ -n "$archive" ]] || { usage; exit 2; }
    echo "[+] Pulling decoder machine..."
    docker pull "$IMAGE" >/dev/null
    docker run --rm --network=none --read-only --cap-drop=ALL \
      -v "$(pwd)":/data:rw \
      "$IMAGE" verify "/data/$archive"
    ;;
  decompress)
    archive="${2:-}"
    output="${3:-}"
    [[ -n "$archive" && -n "$output" ]] || { usage; exit 2; }
    echo "[+] Pulling decoder machine..."
    docker pull "$IMAGE" >/dev/null
    docker run --rm --network=none --read-only --cap-drop=ALL \
      -v "$(pwd)":/data:rw \
      "$IMAGE" decompress "/data/$archive" -o "/data/$output"
    ;;
  *)
    usage; exit 2
    ;;
esac
